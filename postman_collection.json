{
  "info": {
    "name": "API de Pedidos - Jitterbit",
    "description": "Coleção Postman para a API de Pedidos do desafio técnico Jitterbit.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json.token) {",
              "    pm.collectionVariables.set('jwtToken', json.token);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Order - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroPedido\": \"v10089015vdb-01\",\n  \"valorTotal\": 10000,\n  \"dataCriacao\": \"2023-07-19T12:24:11.5299601+00:00\",\n  \"items\": [\n    {\n      \"idItem\": \"2434\",\n      \"quantidadeItem\": 1,\n      \"valorItem\": 1000\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/order",
          "host": ["{{baseUrl}}"],
          "path": ["order"]
        }
      }
    },
    {
      "name": "Order - Get by Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/order/v10089015vdb-01",
          "host": ["{{baseUrl}}"],
          "path": ["order", "v10089015vdb-01"]
        }
      }
    },
    {
      "name": "Order - List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/order/list",
          "host": ["{{baseUrl}}"],
          "path": ["order", "list"]
        }
      }
    },
    {
      "name": "Order - Update",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroPedido\": \"v10089015vdb-01\",\n  \"valorTotal\": 12000,\n  \"dataCriacao\": \"2023-07-19T12:24:11.5299601+00:00\",\n  \"items\": [\n    {\n      \"idItem\": \"2434\",\n      \"quantidadeItem\": 2,\n      \"valorItem\": 6000\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/order/v10089015vdb-01",
          "host": ["{{baseUrl}}"],
          "path": ["order", "v10089015vdb-01"]
        }
      }
    },
    {
      "name": "Order - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/order/v10089015vdb-01",
          "host": ["{{baseUrl}}"],
          "path": ["order", "v10089015vdb-01"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "jwtToken",
      "value": ""
    }
  ]
}
